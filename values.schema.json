{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["workloadType", "containers"],
  "definitions": {
    "nodeTargetingProperty": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" },
          "description": "Shorthand: list of values with soft (default) enforcement"
        },
        {
          "type": "object",
          "properties": {
            "values": { "type": "array", "items": { "type": "string" }, "description": "Target values list" },
            "enforcement": { "type": "string", "enum": ["soft", "hard"], "description": "soft (preferred, best-effort) or hard (required, may leave pods unschedulable)" }
          },
          "additionalProperties": false
        }
      ]
    },
    "containerSpec": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "additionalProperties": false
        },
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "ports": {
          "type": "object",
          "description": "Map of port name to port config",
          "additionalProperties": {
            "type": "object",
            "required": ["port"],
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "env": {
          "type": "object",
          "description": "Unified env map. Key = env var name (for value/valueFrom entries) or identifier (for configMapRef/secretRef bulk entries).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "valueFrom": { "type": "object" },
              "configMapRef": { "type": "object" },
              "secretRef": { "type": "object" }
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object" },
            "limits": { "type": "object" }
          },
          "additionalProperties": false
        },
        "resizePolicy": {
          "type": "array",
          "description": "In-place resize policy (K8s 1.35+)",
          "items": {
            "type": "object",
            "required": ["resourceName", "restartPolicy"],
            "properties": {
              "resourceName": { "type": "string" },
              "restartPolicy": { "type": "string", "enum": ["NotRequired", "RestartContainer"] }
            }
          }
        },
        "securityContext": { "type": "object" },
        "healthChecks": {
          "type": "object",
          "properties": {
            "liveness": { "type": "object" },
            "readiness": { "type": "object" },
            "startup": { "type": "object" }
          },
          "additionalProperties": false
        },
        "lifecycle": { "type": "object" },
        "workingDir": { "type": "string" },
        "mounts": {
          "type": "array",
          "description": "Unified mounts list. Each entry has path + one source (configMap/secret/persistence/volume).",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "configMap": { "type": "string" },
              "secret": { "type": "string" },
              "persistence": { "type": "string" },
              "volume": { "type": "string" },
              "external": { "type": "boolean" },
              "readOnly": { "type": "boolean" },
              "subPath": { "type": "string" },
              "items": { "type": "array" },
              "defaultMode": { "type": "integer" }
            }
          }
        }
      }
    },
    "initContainerSpec": {
      "allOf": [
        { "$ref": "#/definitions/containerSpec" },
        {
          "properties": {
            "restartPolicy": { "type": "string", "enum": ["Always", ""], "description": "Set to Always for native sidecar (K8s 1.33+)" }
          }
        }
      ]
    }
  },
  "properties": {
    "workloadType": {
      "type": "string",
      "enum": ["Deployment", "StatefulSet", "CronJob", "Job", "DaemonSet", "Rollout"],
      "description": "Kubernetes workload type to deploy"
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "infraSettings": {
      "type": "object",
      "properties": {
        "nodeLabels": {
          "type": "object",
          "description": "Node label key mapping. Maps friendly names to actual Kubernetes node label keys.",
          "properties": {
            "topologyRegion": { "type": "string", "minLength": 1, "description": "Region topology label key" },
            "topologyZone": { "type": "string", "minLength": 1, "description": "Zone topology label key" },
            "topologyRack": { "type": "string", "minLength": 1, "description": "Rack topology label key" },
            "nodePool": { "type": "string", "minLength": 1, "description": "Node pool label key" },
            "os": { "type": "string", "minLength": 1, "description": "OS label key" },
            "arch": { "type": "string", "minLength": 1, "description": "Architecture label key" },
            "nodeType": { "type": "string", "minLength": 1, "description": "Node type/instance type label key" }
          },
          "additionalProperties": false
        },
        "backups": {
          "type": "object",
          "description": "Backup infrastructure settings provisioned by infra/devops team.",
          "properties": {
            "s3": {
              "type": "object",
              "properties": {
                "bucket": { "type": "string" },
                "path": { "type": "string" },
                "region": { "type": "string" },
                "endpoint": { "type": "string" },
                "credentials": {
                  "type": "object",
                  "properties": {
                    "secretName": { "type": "string" },
                    "accessKeyId": { "type": "string" },
                    "secretAccessKey": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "azure": {
              "type": "object",
              "properties": {
                "storageAccount": { "type": "string" },
                "path": { "type": "string" },
                "credentials": {
                  "type": "object",
                  "properties": {
                    "secretName": { "type": "string" },
                    "connectionString": { "type": "string" },
                    "storageAccount": { "type": "string" },
                    "storageKey": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "gcs": {
              "type": "object",
              "properties": {
                "bucket": { "type": "string" },
                "path": { "type": "string" },
                "credentials": {
                  "type": "object",
                  "properties": {
                    "secretName": { "type": "string" },
                    "applicationCredentials": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "argocd": {
      "type": "object",
      "properties": {
        "syncWaves": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "description": "Auto-assign sync wave annotations to all resources" }
          }
        },
        "syncOptions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sync options applied to all resources (e.g. ServerSideApply=true)"
        }
      }
    },
    "containers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/containerSpec" },
      "description": "Map of container name to container spec"
    },
    "initContainers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/initContainerSpec" },
      "description": "Map of init container name to container spec (processed in alphabetical key order)"
    },
    "nodeTargeting": {
      "type": "object",
      "properties": {
        "restrictions": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["differentNodes", "sameNode", "none"], "description": "Placement type: differentNodes (spread), sameNode (colocate), none" },
            "enforcement": { "type": "string", "enum": ["soft", "hard"], "description": "soft (preferred, best-effort) or hard (required, may leave pods unschedulable)" }
          },
          "additionalProperties": false
        },
        "os": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target OS(es)" },
        "arch": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target architecture(s)" },
        "regions": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target region(s)" },
        "zones": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target zone(s)" },
        "racks": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target rack(s)" },
        "nodeTypes": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target node/instance type(s)" },
        "nodePools": { "$ref": "#/definitions/nodeTargetingProperty", "description": "Target node pool(s)" }
      },
      "additionalProperties": false
    },
    "podSettings": {
      "type": "object",
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "name": { "type": "string" } },
            "required": ["name"]
          }
        },
        "securityContext": { "type": "object" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "volumes": { "type": "array", "items": { "type": "object" } },
        "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": {
          "type": "object",
          "description": "Map of topology spread constraint name to config. labelSelector defaults to chart's selectorLabels.",
          "additionalProperties": {
            "type": "object",
            "required": ["topologyKey"],
            "properties": {
              "maxSkew": { "type": "integer", "minimum": 1 },
              "topologyKey": { "type": "string" },
              "whenUnsatisfiable": { "type": "string", "enum": ["DoNotSchedule", "ScheduleAnyway"] },
              "labelSelector": { "type": "object" },
              "matchLabelKeys": { "type": "array", "items": { "type": "string" } },
              "minDomains": { "type": "integer" },
              "nodeAffinityPolicy": { "type": "string", "enum": ["Honor", "Ignore"] },
              "nodeTaintsPolicy": { "type": "string", "enum": ["Honor", "Ignore"] }
            }
          }
        },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": ["integer", "string"] },
        "dnsPolicy": { "type": "string" },
        "dnsConfig": { "type": "object" },
        "hostNetwork": { "type": "boolean" },
        "restartPolicy": { "type": "string", "enum": ["Always", "OnFailure", "Never", ""] }
      },
      "additionalProperties": false
    },
    "networking": {
      "type": "object",
      "properties": {
        "services": {
          "type": "object",
          "description": "Map of service name to service config",
          "additionalProperties": {
            "type": "object",
            "required": ["ports"],
            "properties": {
              "headless": { "type": "boolean", "description": "Set true for clusterIP: None" },
              "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
              "ports": {
                "type": "object",
                "minProperties": 1,
                "description": "Map of port name to port config",
                "additionalProperties": {
                  "type": "object",
                  "required": ["port"],
                  "properties": {
                    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                    "containerPort": { "type": "string", "description": "Container port name, defaults to port key name" },
                    "protocol": { "type": "string" },
                    "nodePort": { "type": "integer" }
                  }
                }
              },
              "clusterIP": { "type": "string" },
              "loadBalancerIP": { "type": "string" },
              "loadBalancerSourceRanges": { "type": "array", "items": { "type": "string" } },
              "externalTrafficPolicy": { "type": "string", "enum": ["Cluster", "Local", ""] },
              "trafficDistribution": { "type": "string", "description": "Traffic distribution: PreferSameNode or PreferSameZone (K8s 1.35+)" },
              "sessionAffinity": { "type": "string" },
              "ipFamilyPolicy": { "type": "string" },
              "ipFamilies": { "type": "array", "items": { "type": "string" } },
              "publishNotReadyAddresses": { "type": "boolean" },
              "selectorLabels": { "type": "object", "additionalProperties": { "type": "string" } },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        },
        "oauth2Proxies": {
          "type": "object",
          "description": "Map of oauth2 proxy name to proxy config",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "mode": { "type": "string", "enum": ["sidecar", "deployment"], "description": "sidecar (default) runs in app pod, deployment creates separate pods" },
              "image": { "type": "object" },
              "replicas": { "type": "integer", "description": "Only for deployment mode" },
              "port": { "type": "integer" },
              "portName": { "type": "string", "description": "Port name suffix (default: proxy)" },
              "provider": { "type": "string" },
              "issuerUrl": { "type": "string" },
              "emailDomains": { "type": "array", "items": { "type": "string" } },
              "upstream": { "type": "string", "description": "Override auto-derived upstream URL" },
              "extraArgs": { "type": "object", "additionalProperties": { "type": "string" } },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": { "type": "object" },
              "resources": { "type": "object" },
              "securityContext": { "type": "object" },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        },
        "ingresses": {
          "type": "object",
          "description": "Map of ingress name to ingress config",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "oauth2Proxy": { "type": "string", "description": "Key from networking.oauth2Proxies map" },
              "className": { "type": "string" },
              "annotations": { "type": "object" },
              "labels": { "type": "object" },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["host", "paths"],
                  "properties": {
                    "host": { "type": "string" },
                    "paths": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["path"],
                        "properties": {
                          "path": { "type": "string" },
                          "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] },
                          "serviceName": { "type": "string" },
                          "servicePort": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              },
              "tls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "secretName": { "type": "string" },
                    "hosts": { "type": "array", "items": { "type": "string" } }
                  }
                }
              },
              "defaultBackend": { "type": "object" }
            }
          }
        },
        "gatewayApi": {
          "type": "object",
          "properties": {
            "routes": {
              "type": "object",
              "description": "Gateway API routes map",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "oauth2Proxy": { "type": "string", "description": "Key from networking.oauth2Proxies map" },
                  "kind": { "type": "string", "enum": ["HTTPRoute", "GRPCRoute", "TLSRoute", "TCPRoute", "UDPRoute"] },
                  "parentRefs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["name"],
                      "properties": {
                        "name": { "type": "string" },
                        "namespace": { "type": "string" },
                        "sectionName": { "type": "string" },
                        "port": { "type": "integer" }
                      }
                    }
                  },
                  "hostnames": { "type": "array", "items": { "type": "string" } },
                  "rules": { "type": "array", "items": { "type": "object" } },
                  "policies": {
                    "type": "object",
                    "properties": {
                      "envoy": {
                        "type": "object",
                        "description": "Envoy Gateway BackendTrafficPolicy settings",
                        "properties": {
                          "loadBalancer": { "type": "object" },
                          "circuitBreaker": { "type": "object" },
                          "retry": { "type": "object" },
                          "timeout": { "type": "object" },
                          "rateLimit": { "type": "object" },
                          "healthCheck": { "type": "object" },
                          "connection": { "type": "object" },
                          "tcpKeepalive": { "type": "object" },
                          "faultInjection": { "type": "object" },
                          "useClientProtocol": { "type": "boolean" },
                          "proxyProtocol": { "type": "object" },
                          "compression": { "type": "array" },
                          "http2": { "type": "object" },
                          "dns": { "type": "object" },
                          "annotations": { "type": "object" },
                          "labels": { "type": "object" }
                        }
                      }
                    }
                  },
                  "annotations": { "type": "object" },
                  "labels": { "type": "object" }
                }
              }
            }
          },
          "additionalProperties": false
        },
        "certificates": {
          "type": "object",
          "description": "Map of cert-manager Certificate name to config",
          "additionalProperties": {
            "type": "object",
            "required": ["issuerRef"],
            "properties": {
              "issuerRef": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "kind": { "type": "string", "enum": ["Issuer", "ClusterIssuer"] },
                  "group": { "type": "string" }
                }
              },
              "secretName": { "type": "string", "description": "Target secret name (defaults to <fullname>-<key>-tls)" },
              "mount": {
                "type": "object",
                "description": "Auto-mount the certificate secret to all containers",
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "description": "Mount path in containers" }
                },
                "additionalProperties": false
              },
              "commonName": { "type": "string" },
              "dnsNames": { "type": "array", "items": { "type": "string" } },
              "ipAddresses": { "type": "array", "items": { "type": "string" } },
              "uris": { "type": "array", "items": { "type": "string" } },
              "emailAddresses": { "type": "array", "items": { "type": "string" } },
              "duration": { "type": "string" },
              "renewBefore": { "type": "string" },
              "privateKey": { "type": "object" },
              "usages": { "type": "array", "items": { "type": "string" } },
              "isCA": { "type": "boolean" },
              "subject": { "type": "object" },
              "keystores": { "type": "object" },
              "secretTemplate": { "type": "object" },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        },
        "networkPolicies": {
          "type": "object",
          "description": "Map of NetworkPolicy name to config",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "podSelector": { "type": "object", "description": "Pod selector (defaults to chart's selectorLabels)" },
              "policyTypes": { "type": "array", "items": { "type": "string", "enum": ["Ingress", "Egress"] } },
              "ingress": { "type": "array", "items": { "type": "object" } },
              "egress": { "type": "array", "items": { "type": "object" } },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        },
        "istio": {
          "type": "object",
          "properties": {
            "virtualServices": {
              "type": "object",
              "description": "Map of VirtualService name to config",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "hosts": { "type": "array", "items": { "type": "string" } },
                  "gateways": { "type": "array", "items": { "type": "string" } },
                  "exportTo": { "type": "array", "items": { "type": "string" } },
                  "http": { "type": "array", "items": { "type": "object" } },
                  "tcp": { "type": "array", "items": { "type": "object" } },
                  "tls": { "type": "array", "items": { "type": "object" } },
                  "annotations": { "type": "object" },
                  "labels": { "type": "object" }
                }
              }
            },
            "destinationRules": {
              "type": "object",
              "description": "Map of DestinationRule name to config",
              "additionalProperties": {
                "type": "object",
                "required": ["host"],
                "properties": {
                  "host": { "type": "string", "description": "Service key (auto-prefixed) or FQDN (with externalHost: true)" },
                  "externalHost": { "type": "boolean", "description": "Skip auto-prefixing the host" },
                  "trafficPolicy": { "type": "object" },
                  "subsets": { "type": "array", "items": { "type": "object" } },
                  "exportTo": { "type": "array", "items": { "type": "string" } },
                  "annotations": { "type": "object" },
                  "labels": { "type": "object" }
                }
              }
            },
            "peerAuthentication": {
              "type": "object",
              "description": "Map of PeerAuthentication name to config",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "selector": { "type": "object", "description": "Workload selector (defaults to chart's selectorLabels)" },
                  "mtls": { "type": "object" },
                  "portLevelMtls": { "type": "object" },
                  "annotations": { "type": "object" },
                  "labels": { "type": "object" }
                }
              }
            },
            "authorizationPolicies": {
              "type": "object",
              "description": "Map of AuthorizationPolicy name to config",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "selector": { "type": "object", "description": "Workload selector (defaults to chart's selectorLabels)" },
                  "action": { "type": "string", "enum": ["ALLOW", "DENY", "CUSTOM", "AUDIT"] },
                  "rules": { "type": "array", "items": { "type": "object" } },
                  "annotations": { "type": "object" },
                  "labels": { "type": "object" }
                }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "configMaps": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "data": { "type": "object", "additionalProperties": { "type": "string" } },
              "binaryData": { "type": "object" },
              "reloaderEnabled": { "type": "boolean", "description": "Include in Stakater Reloader annotations (default: true)" },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "data": { "type": "object" },
              "stringData": { "type": "object", "additionalProperties": { "type": "string" } },
              "generate": {
                "type": "object",
                "description": "Auto-generate random values via ESO Password generators",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "length": { "type": "integer" },
                    "digits": { "type": "integer" },
                    "symbols": { "type": "integer" },
                    "symbolCharacters": { "type": "string" },
                    "noUpper": { "type": "boolean" },
                    "allowRepeat": { "type": "boolean" },
                    "encoding": { "type": "string", "enum": ["raw", "base64", "base64url", "base32", "hex"] }
                  }
                }
              },
              "generateRefreshInterval": { "type": "string", "description": "Refresh interval for generated secrets. 0 = generate once." },
