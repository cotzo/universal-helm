{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["workloadType", "containers"],
  "definitions": {
    "containerSpec": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "additionalProperties": false
        },
        "command": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "array", "items": { "type": "string" } },
        "ports": {
          "type": "object",
          "description": "Map of port name to port config",
          "additionalProperties": {
            "type": "object",
            "required": ["port"],
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "env": {
          "type": "object",
          "description": "Unified env map. Key = env var name (for value/valueFrom entries) or identifier (for configMapRef/secretRef bulk entries).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "valueFrom": { "type": "object" },
              "configMapRef": { "type": "object" },
              "secretRef": { "type": "object" }
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object" },
            "limits": { "type": "object" }
          },
          "additionalProperties": false
        },
        "resizePolicy": {
          "type": "array",
          "description": "In-place resize policy (K8s 1.35+)",
          "items": {
            "type": "object",
            "required": ["resourceName", "restartPolicy"],
            "properties": {
              "resourceName": { "type": "string" },
              "restartPolicy": { "type": "string", "enum": ["NotRequired", "RestartContainer"] }
            }
          }
        },
        "securityContext": { "type": "object" },
        "healthChecks": {
          "type": "object",
          "properties": {
            "liveness": { "type": "object" },
            "readiness": { "type": "object" },
            "startup": { "type": "object" }
          },
          "additionalProperties": false
        },
        "lifecycle": { "type": "object" },
        "workingDir": { "type": "string" },
        "mounts": {
          "type": "array",
          "description": "Unified mounts list. Each entry has path + one source (configMap/secret/persistence/volume).",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "configMap": { "type": "string" },
              "secret": { "type": "string" },
              "persistence": { "type": "string" },
              "volume": { "type": "string" },
              "external": { "type": "boolean" },
              "readOnly": { "type": "boolean" },
              "subPath": { "type": "string" },
              "items": { "type": "array" },
              "defaultMode": { "type": "integer" }
            }
          }
        }
      }
    },
    "initContainerSpec": {
      "allOf": [
        { "$ref": "#/definitions/containerSpec" },
        {
          "properties": {
            "restartPolicy": { "type": "string", "enum": ["Always", ""], "description": "Set to Always for native sidecar (K8s 1.33+)" }
          }
        }
      ]
    }
  },
  "properties": {
    "workloadType": {
      "type": "string",
      "enum": ["Deployment", "StatefulSet", "CronJob", "Job", "DaemonSet", "Rollout"],
      "description": "Kubernetes workload type to deploy"
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "containers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/containerSpec" },
      "description": "Map of container name to container spec"
    },
    "initContainers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/initContainerSpec" },
      "description": "Map of init container name to container spec (processed in alphabetical key order)"
    },
    "nodeSettings": {
      "type": "object",
      "properties": {
        "os": { "type": "array", "items": { "type": "string" }, "description": "Target OS(es) (kubernetes.io/os)" },
        "arch": { "type": "array", "items": { "type": "string" }, "description": "Target architecture(s) (kubernetes.io/arch)" }
      },
      "additionalProperties": false
    },
    "podSettings": {
      "type": "object",
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "name": { "type": "string" } },
            "required": ["name"]
          }
        },
        "securityContext": { "type": "object" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "volumes": { "type": "array", "items": { "type": "object" } },
        "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
        "tolerations": { "type": "array", "items": { "type": "object" } },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": ["integer", "string"] },
        "dnsPolicy": { "type": "string" },
        "dnsConfig": { "type": "object" },
        "hostNetwork": { "type": "boolean" },
        "restartPolicy": { "type": "string", "enum": ["Always", "OnFailure", "Never", ""] }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "object",
      "description": "Map of service name to service config",
      "additionalProperties": {
        "type": "object",
        "required": ["ports"],
        "properties": {
          "headless": { "type": "boolean", "description": "Set true for clusterIP: None" },
          "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
          "ports": {
            "type": "object",
            "minProperties": 1,
            "description": "Map of port name to port config",
            "additionalProperties": {
              "type": "object",
              "required": ["port"],
              "properties": {
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "containerPort": { "type": "string", "description": "Container port name, defaults to port key name" },
                "protocol": { "type": "string" },
                "nodePort": { "type": "integer" }
              }
            }
          },
          "clusterIP": { "type": "string" },
          "loadBalancerIP": { "type": "string" },
          "loadBalancerSourceRanges": { "type": "array", "items": { "type": "string" } },
          "externalTrafficPolicy": { "type": "string", "enum": ["Cluster", "Local", ""] },
          "trafficDistribution": { "type": "string", "description": "Traffic distribution: PreferSameNode or PreferSameZone (K8s 1.35+)" },
          "sessionAffinity": { "type": "string" },
          "ipFamilyPolicy": { "type": "string" },
          "ipFamilies": { "type": "array", "items": { "type": "string" } },
          "publishNotReadyAddresses": { "type": "boolean" },
          "selectorLabels": { "type": "object", "additionalProperties": { "type": "string" } },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "oauth2Proxies": {
      "type": "object",
      "description": "Map of oauth2 proxy name to proxy config",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["sidecar", "deployment"], "description": "sidecar (default) runs in app pod, deployment creates separate pods" },
          "image": { "type": "object" },
          "replicas": { "type": "integer", "description": "Only for deployment mode" },
          "port": { "type": "integer" },
          "portName": { "type": "string", "description": "Port name suffix (default: proxy)" },
          "provider": { "type": "string" },
          "issuerUrl": { "type": "string" },
          "emailDomains": { "type": "array", "items": { "type": "string" } },
          "upstream": { "type": "string", "description": "Override auto-derived upstream URL" },
          "extraArgs": { "type": "object", "additionalProperties": { "type": "string" } },
          "args": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "object" },
          "resources": { "type": "object" },
          "securityContext": { "type": "object" },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "ingresses": {
      "type": "object",
      "description": "Map of ingress name to ingress config",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "oauth2Proxy": { "type": "string", "description": "Key from oauth2Proxies map" },
          "className": { "type": "string" },
          "annotations": { "type": "object" },
          "labels": { "type": "object" },
          "hosts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["host", "paths"],
              "properties": {
                "host": { "type": "string" },
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["path"],
                    "properties": {
                      "path": { "type": "string" },
                      "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] },
                      "serviceName": { "type": "string" },
                      "servicePort": { "type": "integer" }
                    }
                  }
                }
              }
            }
          },
          "tls": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "secretName": { "type": "string" },
                "hosts": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "defaultBackend": { "type": "object" }
        }
      }
    },
    "gatewayApi": {
      "type": "object",
      "properties": {
        "routes": {
          "type": "object",
          "description": "Gateway API routes map",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "oauth2Proxy": { "type": "string", "description": "Key from oauth2Proxies map" },
              "kind": { "type": "string", "enum": ["HTTPRoute", "GRPCRoute", "TLSRoute", "TCPRoute", "UDPRoute"] },
              "parentRefs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": { "type": "string" },
                    "namespace": { "type": "string" },
                    "sectionName": { "type": "string" },
                    "port": { "type": "integer" }
                  }
                }
              },
              "hostnames": { "type": "array", "items": { "type": "string" } },
              "rules": { "type": "array", "items": { "type": "object" } },
              "policies": {
                "type": "object",
                "properties": {
                  "envoy": {
                    "type": "object",
                    "description": "Envoy Gateway BackendTrafficPolicy settings",
                    "properties": {
                      "loadBalancer": { "type": "object" },
                      "circuitBreaker": { "type": "object" },
                      "retry": { "type": "object" },
                      "timeout": { "type": "object" },
                      "rateLimit": { "type": "object" },
                      "healthCheck": { "type": "object" },
                      "connection": { "type": "object" },
                      "tcpKeepalive": { "type": "object" },
                      "faultInjection": { "type": "object" },
                      "useClientProtocol": { "type": "boolean" },
                      "proxyProtocol": { "type": "object" },
                      "compression": { "type": "array" },
                      "http2": { "type": "object" },
                      "dns": { "type": "object" },
                      "annotations": { "type": "object" },
                      "labels": { "type": "object" }
                    }
                  }
                }
              },
              "annotations": { "type": "object" },
              "labels": { "type": "object" }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "configMaps": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "data": { "type": "object", "additionalProperties": { "type": "string" } },
          "binaryData": { "type": "object" },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "data": { "type": "object" },
          "stringData": { "type": "object", "additionalProperties": { "type": "string" } },
          "generate": {
            "type": "object",
            "description": "Auto-generate random values via ESO Password generators",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "length": { "type": "integer" },
                "digits": { "type": "integer" },
                "symbols": { "type": "integer" },
                "symbolCharacters": { "type": "string" },
                "noUpper": { "type": "boolean" },
                "allowRepeat": { "type": "boolean" },
                "encoding": { "type": "string", "enum": ["raw", "base64", "base64url", "base32", "hex"] }
              }
            }
          },
          "generateRefreshInterval": { "type": "string", "description": "Refresh interval for generated secrets. 0 = generate once." },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "refreshInterval": { "type": "string" },
          "secretStoreRef": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"] }
            }
          },
          "target": { "type": "object" },
          "data": { "type": "array" },
          "dataFrom": { "type": "array" },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "storageClass": { "type": "string" },
          "accessModes": { "type": "array", "items": { "type": "string" } },
          "size": { "type": "string" },
          "existingClaim": { "type": "string" },
          "volumeName": { "type": "string" },
          "selector": { "type": "object" },
          "annotations": { "type": "object" },
          "labels": { "type": "object" }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "hpa": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "metrics": { "type": "array", "items": { "type": "object" } },
            "behavior": { "type": "object" },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          },
          "additionalProperties": false
        },
        "keda": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicaCount": { "type": "integer", "minimum": 0 },
            "maxReplicaCount": { "type": "integer", "minimum": 1 },
            "pollingInterval": { "type": ["integer", "string"] },
            "cooldownPeriod": { "type": ["integer", "string"] },
            "idleReplicaCount": { "type": ["integer", "string"] },
            "fallback": { "type": "object" },
            "advanced": { "type": "object" },
            "triggers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "metadata"],
                "properties": {
                  "type": { "type": "string" },
                  "name": { "type": "string" },
                  "metadata": { "type": "object" },
                  "authenticationRef": { "type": "object" },
                  "metricType": { "type": "string" }
                }
              }
            },
            "successfulJobsHistoryLimit": { "type": ["integer", "string"], "description": "ScaledJob: successful jobs history limit" },
            "failedJobsHistoryLimit": { "type": ["integer", "string"], "description": "ScaledJob: failed jobs history limit" },
            "scalingStrategy": { "type": "object", "description": "ScaledJob: scaling strategy configuration" },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] },
        "unhealthyPodEvictionPolicy": { "type": "string" },
        "annotations": { "type": "object" },
        "labels": { "type": "object" }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "labels": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" },
        "imagePullSecrets": { "type": "array" }
      },
      "additionalProperties": false
    },
    "rbac": {
      "type": "object",
      "properties": {
        "roles": { "type": "object", "additionalProperties": { "type": "object" } },
        "clusterRoles": { "type": "object", "additionalProperties": { "type": "object" } },
        "roleBindings": { "type": "object", "additionalProperties": { "type": "object" } },
        "clusterRoleBindings": { "type": "object", "additionalProperties": { "type": "object" } }
      },
      "additionalProperties": false
    },
    "monitors": {
      "type": "object",
      "description": "Map of monitor name to monitor config",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "kind": { "type": "string", "enum": ["service", "pod"] },
          "operator": { "type": "string", "enum": ["prometheus", "victoriametrics"] },
          "port": { "type": "string" },
          "path": { "type": "string" },
          "interval": { "type": "string" },
          "scrapeTimeout": { "type": "string" },
          "scheme": { "type": "string" },
          "honorLabels": { "type": "boolean" },
          "honorTimestamps": { "type": "boolean" },
          "followRedirects": { "type": "boolean" },
          "params": { "type": "object" },
          "tlsConfig": { "type": "object" },
          "bearerTokenSecret": { "type": "object" },
          "basicAuth": { "type": "object" },
          "authorization": { "type": "object" },
          "oauth2": { "type": "object" },
          "proxyURL": { "type": "string" },
          "metricRelabelings": { "type": "array" },
          "relabelings": { "type": "array" },
          "endpoints": { "type": "array" },
          "selector": { "type": "object" },
          "namespaceSelector": { "type": "object" },
          "jobLabel": { "type": "string" },
          "targetLabels": { "type": "array", "items": { "type": "string" } },
          "podTargetLabels": { "type": "array", "items": { "type": "string" } },
          "sampleLimit": { "type": "integer" },
          "vmScrapeParams": { "type": "object", "description": "VictoriaMetrics-specific scrape params" },
          "maxScrapeSize": { "type": "string", "description": "VictoriaMetrics-specific max scrape size" },
          "seriesLimit": { "type": "integer", "description": "VictoriaMetrics-specific series limit" },
          "labels": { "type": "object" },
          "annotations": { "type": "object" }
        }
      }
    },
    "rollout": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0, "description": "Number of replicas" },
        "strategy": { "type": "object", "description": "Argo Rollout strategy (canary or blueGreen)" },
        "minReadySeconds": { "type": ["integer", "string"] },
        "revisionHistoryLimit": { "type": ["integer", "string"] },
        "restartAt": { "type": "string", "description": "Restart at time (RFC 3339 format)" },
        "analysis": { "type": "object", "description": "Background analysis configuration" }
      },
      "additionalProperties": false
    },
    "deployment": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0, "description": "Number of replicas" },
        "strategy": { "type": "object" },
        "minReadySeconds": { "type": ["integer", "string"] },
        "revisionHistoryLimit": { "type": ["integer", "string"] }
      },
      "additionalProperties": false
    },
    "statefulSet": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0, "description": "Number of replicas" },
        "serviceName": { "type": "string" },
        "publishNotReadyAddresses": { "type": "boolean" },
        "podManagementPolicy": { "type": "string", "enum": ["OrderedReady", "Parallel", ""] },
        "updateStrategy": { "type": "object" },
        "minReadySeconds": { "type": ["integer", "string"] },
        "revisionHistoryLimit": { "type": ["integer", "string"] },
        "ordinals": { "type": "object" },
        "persistentVolumeClaimRetentionPolicy": { "type": "object" }
      },
      "additionalProperties": false
    },
    "daemonSet": {
      "type": "object",
      "properties": {
        "updateStrategy": { "type": "object" },
        "minReadySeconds": { "type": ["integer", "string"] },
        "revisionHistoryLimit": { "type": ["integer", "string"] }
      },
      "additionalProperties": false
    },
    "cronJob": {
      "type": "object",
      "properties": {
        "schedule": { "type": "string" },
        "timeZone": { "type": "string" },
        "concurrencyPolicy": { "type": "string", "enum": ["Allow", "Forbid", "Replace", ""] },
        "suspend": { "type": "boolean" },
        "successfulJobsHistoryLimit": { "type": ["integer", "string"] },
        "failedJobsHistoryLimit": { "type": ["integer", "string"] },
        "startingDeadlineSeconds": { "type": ["integer", "string"] }
      },
      "additionalProperties": false
    },
    "job": {
      "type": "object",
      "properties": {
        "backoffLimit": { "type": ["integer", "string"] },
        "activeDeadlineSeconds": { "type": ["integer", "string"] },
        "ttlSecondsAfterFinished": { "type": ["integer", "string"] },
        "completions": { "type": ["integer", "string"] },
        "parallelism": { "type": ["integer", "string"] },
        "completionMode": { "type": "string", "enum": ["NonIndexed", "Indexed", ""] },
        "podReplacementPolicy": { "type": "string", "enum": ["Failed", "TerminatingOrFailed", ""], "description": "Pod replacement policy (K8s 1.34+)" },
        "suspend": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "extraResources": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
